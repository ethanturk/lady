# --- Rust ---
/target/
**/*.rs.bk

# --- Tauri / frontend (per PLAN.md) ---
ui/node_modules/
ui/dist/
src-tauri/target/

# --- Mobile: generated native projects + build artifacts (created by
#     `tauri ios/android init`; those commands also write their own
#     gen/*/.gitignore for the finer-grained build output) ---
src-tauri/gen/

# --- Updater / signing secrets (NEVER commit; only the updater PUBLIC key lives
#     in tauri.conf.json — private keys / certs are CI secrets) ---
*.key
*.p12
*.pfx

# --- OS / editor cruft ---
.DS_Store
*.swp
*~
.idea/
.vscode/*
!.vscode/extensions.json

# --- Project skills: track ONLY .claude/skills/ ---
# (the user's global ~/.gitignore excludes all of .claude/; re-include skills)
!.claude/
.claude/*
!.claude/skills/
!.claude/skills/**
