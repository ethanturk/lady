# --- Rust ---
/target/
**/*.rs.bk

# --- Tauri / frontend (per PLAN.md) ---
ui/node_modules/
ui/dist/
src-tauri/target/

# --- Updater / signing secrets (NEVER commit; only the updater PUBLIC key lives
#     in tauri.conf.json — private keys / certs are CI secrets) ---
*.key
*.p12
*.pfx

# --- OS / editor cruft ---
.DS_Store
*.swp
*~
.idea/
.vscode/*
!.vscode/extensions.json

# --- Project skills: track ONLY .claude/skills/ ---
# (the user's global ~/.gitignore excludes all of .claude/; re-include skills)
!.claude/
.claude/*
!.claude/skills/
!.claude/skills/**
