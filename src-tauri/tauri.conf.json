{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lady",
  "version": "1.2.0",
  "identifier": "dev.lady.client",
  "build": {
    "frontendDist": "../ui/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": { "cwd": "../ui", "script": "npm run dev" },
    "beforeBuildCommand": { "cwd": "../ui", "script": "npm run build" }
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Lady",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false
  }
}
